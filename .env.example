# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google OAuth 2.0 Client credentials (obtain from Google API Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLIENT_ID=
CLIENT_SECRET=

# SMTP Email Server Configuration for sending real verification codes to Gmails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# APP_URL: Dynamically injected by AI Studio at runtime
APP_URL=
